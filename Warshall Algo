#include <stdio.h>

#define MAX 10

void warshall(int n, int A[MAX][MAX]) {
    int P[MAX][MAX];


    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            P[i][j] = A[i][j];
        }
    }

    
    for (int k = 0; k < n; k++) {
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                P[i][j] = P[i][j] || (P[i][k] && P[k][j]);
            }
        }
    }

    
    printf("Transitive Closure Matrix:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            printf("%d ", P[i][j]);
        }
        printf("\n");
    }
}

int main() {
    int n, A[MAX][MAX];

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &A[i][j]);
        }
    }

    warshall(n, A);

    return 0;
}
